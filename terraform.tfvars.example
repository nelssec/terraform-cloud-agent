# =============================================================================
# Qualys Credentials
# =============================================================================

# Get ActivationId and CustomerId from Qualys Console > Assets > Agents
qualys_activation_id = "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
qualys_customer_id   = "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# Agent server URI — where the installed agent phones home.
# Find yours at: https://www.qualys.com/platform-identification
# Examples:
#   US Platform 1:  https://qagpublic.qg1.apps.qualys.com/CloudAgent/
#   US Platform 2:  https://qagpublic.qg2.apps.qualys.com/CloudAgent/
#   US Platform 3:  https://qagpublic.qg3.apps.qualys.com/CloudAgent/
#   EU Platform 1:  https://qagpublic.qg1.apps.qualys.eu/CloudAgent/
#   India:          https://qagpublic.qg1.apps.qualys.in/CloudAgent/
qualys_server_uri = "https://qagpublic.qg2.apps.qualys.com/CloudAgent/"

# Pre-staged installer packages. Download the Qualys Cloud Agent binaries once
# from the Qualys Console (Cloud Agent > Agent Installation) and host them where
# your instances can reach them (a bucket, internal mirror, etc.). Instances pull
# these directly — no Qualys API credentials are placed on the fleet.
# Provide only the entries matching your target OSes.
qualys_packages = {
  deb     = "https://my-mirror.example.com/qualys/QualysCloudAgent.deb"
  rpm     = "https://my-mirror.example.com/qualys/QualysCloudAgent.rpm"
  windows = "https://my-mirror.example.com/qualys/QualysCloudAgent.exe"
}

# =============================================================================
# Deployment Settings
# =============================================================================

environment   = "prod"
deployment_id = "qualys-2024-01"

tags = {
  owner       = "security-team"
  cost_center = "it-security"
}

# =============================================================================
# Enable clouds
# =============================================================================

deploy_to_gcp      = true
deploy_to_aws      = false
deploy_to_azure    = false
deploy_to_oci      = false
deploy_to_alicloud = false

# =============================================================================
# GCP
# =============================================================================

gcp_config = {
  project_id = "my-gcp-project-id"
  region     = "us-central1"
  zones      = ["us-central1-a", "us-central1-b", "us-central1-c"]

  # Opt-in: only VMs with label qualys-agent=true
  target_all_vms   = false
  inclusion_labels = { "qualys-agent" = "true" }
  exclusion_labels = {}
  rollout_percent  = 10
}

